# Database
DATABASE_URL=postgresql+asyncpg://finuser:strongpassword123@localhost:5432/financemanager

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# CORS — list of allowed origins (JSON array string)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Dashboard authentication
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_64_char_hex_string_here

TOKEN_EXPIRE_HOURS=24

DASHBOARD_USERNAME=admin

# Generate DASHBOARD_PASSWORD_HASH (bcrypt) — replace 'yourpassword' with real password:
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('yourpassword'))"
# Default hash below is for password: "secret" — CHANGE THIS before deploying!
DASHBOARD_PASSWORD_HASH=$2b$12$EixZaYVK1fsbw1ZfbX3OXePaWxn96p36WQoeG6Lruj3vjPGga31lW
